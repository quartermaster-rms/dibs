# The single source of deployment configuration. Copy to deploy/host.env.
# Dev/test and production run the exact same stack; only this file differs.
# All runtime policy (quotas, limits, permission model, slot granularity) is
# configured in-app by admins, never here.

# --- Postgres (internal to the stack; never published) ---
# The password lives here ONCE. The app derives its connection URL from these
# values (URL-encoded), so there is nothing to keep in sync.
# NOTE: Postgres applies POSTGRES_PASSWORD only when it first initialises an
# empty data directory. If you change it after the stack has run once, also
# reset the database volume: `docker compose down -v` (destroys DB data).
POSTGRES_USER=dibs
POSTGRES_PASSWORD=change-me
POSTGRES_DB=dibs
POSTGRES_HOST=postgres
# Set DATABASE_URL only to point at an EXTERNAL database (overrides the above).
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# --- Redis (internal; never published) ---
REDIS_URL=redis://redis:6379/0

# --- Calendar (single campus timezone) ---
PLATFORM_TZ=America/Los_Angeles

# --- Authentication ---
# Dev/test: the hermetic stub-login (the sole auth bypass). Production MUST use
# oidc and MUST NOT set AUTH_MODE=stub.
AUTH_MODE=stub
# Production identity (mutually exclusive with the stub):
#   AUTH_MODE=oidc
#   OIDC_ISSUER=https://keycloak.example/realms/quartermaster
#   OIDC_CLIENT_ID=dibs
#   OIDC_CLIENT_SECRET=change-me
#   OIDC_REDIRECT_URL=https://dibs.example/api/auth/callback
#   OIDC_GROUPS_CLAIM=groups

# --- Session cookie ---
SESSION_SECRET=change-me-to-a-long-random-string
# Production is served over HTTPS by a reverse proxy, so cookies are Secure.
# Set false only for plain-HTTP local dev with no TLS proxy in front.
COOKIE_SECURE=true

# --- Published ports ---
API_PORT=8000
DEVICE_PORT=8443

# --- Device-plane TLS (terminated inside the device container; nodes pin the CA) ---
# The device container runs non-root (uid 10001); the mounted cert/key must be
# readable by it (e.g. `chmod 644`, or owned by uid 10001).
DEVICE_TLS_CERT=/tls/device.crt
DEVICE_TLS_KEY=/tls/device.key
