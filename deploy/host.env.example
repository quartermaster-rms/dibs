# The single source of deployment configuration. Copy to deploy/host.env.
# Dev/test and production run the exact same stack; only this file differs.
# All runtime policy (quotas, limits, permission model, slot granularity) is
# configured in-app by admins, never here.

# --- Postgres (internal to the stack; never published) ---
POSTGRES_USER=dibs
POSTGRES_PASSWORD=change-me
POSTGRES_DB=dibs
DATABASE_URL=postgresql+psycopg://dibs:change-me@postgres:5432/dibs

# --- Redis (internal; never published) ---
REDIS_URL=redis://redis:6379/0

# --- Calendar (single campus timezone) ---
PLATFORM_TZ=America/Los_Angeles

# --- Authentication ---
# Dev/test: the hermetic stub-login (the sole auth bypass). Production MUST use
# oidc and MUST NOT set AUTH_MODE=stub.
AUTH_MODE=stub
# Production identity (mutually exclusive with the stub):
#   AUTH_MODE=oidc
#   OIDC_ISSUER=https://keycloak.example/realms/quartermaster
#   OIDC_CLIENT_ID=dibs
#   OIDC_CLIENT_SECRET=change-me
#   OIDC_REDIRECT_URL=https://dibs.example/api/auth/callback
#   OIDC_GROUPS_CLAIM=groups

# --- Session cookie ---
SESSION_SECRET=change-me-to-a-long-random-string
# true behind the TLS-terminating reverse proxy (production); false for plain-http local dev.
COOKIE_SECURE=false

# --- Published ports ---
API_PORT=8000
DEVICE_PORT=8443

# --- Device-plane TLS (terminated inside the device container; nodes pin the CA) ---
DEVICE_TLS_CERT=/tls/device.crt
DEVICE_TLS_KEY=/tls/device.key

# --- Optional MQTT state publisher (dormant unless configured) ---
# MQTT_URL=mqtts://broker.example:8883
# MQTT_TLS_CA=/tls/mqtt-ca.crt
